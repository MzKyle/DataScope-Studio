{
  "name": "datascope-studio-desktop",
  "private": true,
  "version": "0.3.1",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:tauri": "bash scripts/run-desktop.sh",
    "build": "tsc && vite build",
    "test": "vitest run",
    "preview": "vite preview",
    "runtime:build": "python ../../packaging/runtime/build_runtime.py --output src-tauri/resources/datascope-runtime",
    "runtime:build:dev": "python ../../packaging/runtime/build_runtime.py --output src-tauri/resources/datascope-runtime --use-current-python",
    "clean:local": "python ../../packaging/dev/clean_local_artifacts.py",
    "tauri:dev": "bash scripts/run-desktop.sh",
    "tauri:dev:safe": "DATASCOPE_SAFE_GRAPHICS=1 bash scripts/run-desktop.sh",
    "tauri:build": "python ../../packaging/runtime/build_tauri.py",
    "package:linux": "npm run runtime:build && python ../../packaging/runtime/build_tauri.py --bundles deb,appimage",
    "package:windows": "npm run runtime:build && python ../../packaging/runtime/build_tauri.py --bundles nsis",
    "package:macos": "npm run runtime:build && python ../../packaging/runtime/build_tauri.py --bundles dmg",
    "package:all": "npm run runtime:build && python ../../packaging/runtime/build_tauri.py"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
